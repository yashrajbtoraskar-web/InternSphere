<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>InternSphere</display-name>

    <!-- Welcome File -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ==================== FILTERS ==================== -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.internsphere.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/student/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/profile</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/settings</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>AdminFilter</filter-name>
        <filter-class>com.internsphere.filter.AdminFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AdminFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>StudentFilter</filter-name>
        <filter-class>com.internsphere.filter.StudentFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>StudentFilter</filter-name>
        <url-pattern>/student/*</url-pattern>
    </filter-mapping>

    <!-- ==================== AUTH SERVLETS ==================== -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.internsphere.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/landing</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.internsphere.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.internsphere.controller.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- ==================== ADMIN SERVLETS ==================== -->
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>com.internsphere.controller.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CompanyServlet</servlet-name>
        <servlet-class>com.internsphere.controller.CompanyServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CompanyServlet</servlet-name>
        <url-pattern>/admin/companies</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>InternshipServlet</servlet-name>
        <servlet-class>com.internsphere.controller.InternshipServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>InternshipServlet</servlet-name>
        <url-pattern>/admin/internships</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ApplicationServlet</servlet-name>
        <servlet-class>com.internsphere.controller.ApplicationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ApplicationServlet</servlet-name>
        <url-pattern>/admin/applications</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ExamManageServlet</servlet-name>
        <servlet-class>com.internsphere.controller.ExamManageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ExamManageServlet</servlet-name>
        <url-pattern>/admin/exams</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>QuestionServlet</servlet-name>
        <servlet-class>com.internsphere.controller.QuestionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>QuestionServlet</servlet-name>
        <url-pattern>/admin/questions</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EvaluationServlet</servlet-name>
        <servlet-class>com.internsphere.controller.EvaluationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EvaluationServlet</servlet-name>
        <url-pattern>/admin/evaluate</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReportServlet</servlet-name>
        <servlet-class>com.internsphere.controller.ReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReportServlet</servlet-name>
        <url-pattern>/admin/reports</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AuditServlet</servlet-name>
        <servlet-class>com.internsphere.controller.AuditServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuditServlet</servlet-name>
        <url-pattern>/admin/audit</url-pattern>
    </servlet-mapping>

    <!-- ==================== STUDENT SERVLETS ==================== -->
    <servlet>
        <servlet-name>StudentDashboardServlet</servlet-name>
        <servlet-class>com.internsphere.controller.StudentDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentDashboardServlet</servlet-name>
        <url-pattern>/student/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StudentInternshipServlet</servlet-name>
        <servlet-class>com.internsphere.controller.StudentInternshipServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentInternshipServlet</servlet-name>
        <url-pattern>/student/internships</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentInternshipServlet</servlet-name>
        <url-pattern>/student/apply</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StudentApplicationServlet</servlet-name>
        <servlet-class>com.internsphere.controller.StudentApplicationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentApplicationServlet</servlet-name>
        <url-pattern>/student/applications</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ExamInterfaceServlet</servlet-name>
        <servlet-class>com.internsphere.controller.ExamInterfaceServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ExamInterfaceServlet</servlet-name>
        <url-pattern>/student/exam</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ExamSaveServlet</servlet-name>
        <servlet-class>com.internsphere.controller.ExamSaveServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ExamSaveServlet</servlet-name>
        <url-pattern>/student/exam/save</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ExamSubmitServlet</servlet-name>
        <servlet-class>com.internsphere.controller.ExamSubmitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ExamSubmitServlet</servlet-name>
        <url-pattern>/student/exam/submit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ResultServlet</servlet-name>
        <servlet-class>com.internsphere.controller.ResultServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResultServlet</servlet-name>
        <url-pattern>/student/results</url-pattern>
    </servlet-mapping>

    <!-- ==================== SHARED SERVLETS ==================== -->
    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>com.internsphere.controller.ProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/profile</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SettingsServlet</servlet-name>
        <servlet-class>com.internsphere.controller.SettingsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SettingsServlet</servlet-name>
        <url-pattern>/settings</url-pattern>
    </servlet-mapping>
    <!-- Student Exam List -->
    <servlet>
        <servlet-name>StudentExamListServlet</servlet-name>
        <servlet-class>com.internsphere.controller.StudentExamListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentExamListServlet</servlet-name>
        <url-pattern>/student/exams</url-pattern>
    </servlet-mapping>

    <!-- Tab Switch Tracker -->
    <servlet>
        <servlet-name>TabSwitchServlet</servlet-name>
        <servlet-class>com.internsphere.controller.TabSwitchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TabSwitchServlet</servlet-name>
        <url-pattern>/student/exam/tabswitch</url-pattern>
    </servlet-mapping>

    <!-- Admin Exam Scores -->
    <servlet>
        <servlet-name>AdminExamScoresServlet</servlet-name>
        <servlet-class>com.internsphere.controller.AdminExamScoresServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminExamScoresServlet</servlet-name>
        <url-pattern>/admin/examscores</url-pattern>
    </servlet-mapping>

    <!-- Admin Assign Exam -->
    <servlet>
        <servlet-name>AdminAssignExamServlet</servlet-name>
        <servlet-class>com.internsphere.controller.AdminAssignExamServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminAssignExamServlet</servlet-name>
        <url-pattern>/admin/assign-exam</url-pattern>
    </servlet-mapping>

    <!-- Session Timeout: 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
</web-app>
